Bootstrap: docker
From: rootproject/root:6.30.04-ubuntu22.04

%post

    apt-get update -y
	# Avoid interactive prompts (e.g., tzdata) during non-interactive builds
	export DEBIAN_FRONTEND=noninteractive
	export TZ=Etc/UTC
	ln -fs /usr/share/zoneinfo/$TZ /etc/localtime
	apt-get install -y \
		git \
		cmake \
		python3 \
		python3-dev \
		python3-numpy \
		python3-numpy-dev \
		curl \
		wget \
		build-essential \
		gcc \
		g++ \
		binutils \
		dpkg-dev \
		libssl-dev \
		libx11-dev \
		libxext-dev \
		libxft-dev \
		libxpm-dev \
		libtbb-dev \
		libgif-dev \
		gfortran \
		libpcre3-dev \
		libglu1-mesa-dev \
		libglew-dev \
		libftgl-dev \
		libfftw3-dev \
		libcfitsio-dev \
		libgraphviz-dev \
		libavahi-compat-libdnssd-dev \
		libldap2-dev \
		libxml2-dev \
		libkrb5-dev \
		qtwebengine5-dev \
		nlohmann-json3-dev \
		libmysqlclient-dev \
		libgl2ps-dev \
		liblzma-dev \
		libxxhash-dev \
		liblz4-dev \
		libzstd-dev \
		libgsl-dev

	# Ensure tzdata is configured without prompting
	if dpkg -s tzdata >/dev/null 2>&1; then dpkg-reconfigure -f noninteractive tzdata; fi

	cd 

    git clone https://github.gatech.edu/aotte6/TrinitySims.git
	cd TrinitySims
	git fetch --all
	git checkout atmospherics-apptainer

    cd ROBAST/ROBAST-3.2.0/
	make clean
	make

	cd

	cd TrinitySims/CHASM_NuSpacesim/
	apt-get install -y python3-pip
	python3 -m pip install -e .

	
	cd

	cd TrinitySims/corsikaIOreader/
	make clean
	make corsikaIOreader

	export LD_LIBRARY_PATH=~/TrinitySims/ROBAST/ROBAST-3.2.0:$LD_LIBRARY_PATH
	export ROOT_INCLUDE_PATH=~/TrinitySims/ROBAST/ROBAST-3.2.0/include


	
	cd

	cd TrinitySims/GrOptics/
	apt-get install -y xutils-dev
	make clean
	make grOptics
	
	cd

	cd TrinitySims/CARE

	# If the VBF directory already exists, remove it; otherwise continue
	if [ -d "VBF-0.3.4-c-17" ]; then
		echo "Found existing VBF-0.3.4-c-17 — removing..."
		rm -rf "VBF-0.3.4-c-17"
	fi
	tar -xzvf VBF-0.3.4-c-17.tar.gz
	cd VBF-0.3.4-c-17
	./configure CXXFLAGS='-pthread -std=c++17 -m64 -I/root/root-6.30.04/rinstall/include' --prefix=/root/TrinitySims/CARE
	make
	make install
	export PATH=$PATH:/root/TrinitySims/CARE/VBF-0.3.4-c-17/vbfTools
	cd /root/TrinitySims/CARE/
	make clean
	make

	echo "Success!"



%environment
    export ROBROOT=/root/TrinitySims/ROBAST/ROBAST-3.2.0
	export LD_LIBRARY_PATH=$ROBROOT:/usr/local/lib:/usr/lib/oracle/21/client64/lib:/exact/dict:$LD_LIBRARY_PATH
	export ROOT_INCLUDE_PATH=$ROBROOT/include:$ROOT_INCLUDE_PATH
	export PATH=$PATH:/root/TrinitySims/CARE/VBF-0.3.4-c-17/vbfTools
	export LD_LIBRARY_PATH=/root/TrinitySims/CARE/lib:$LD_LIBRARY_PATH


%runscript
    exec bash /root/TrinitySims/BatchSubmissionScripts/Hive_SequentialChainJobPerShower/runTrinityShowersMCSequentialChain_noroot.sh "$@"
