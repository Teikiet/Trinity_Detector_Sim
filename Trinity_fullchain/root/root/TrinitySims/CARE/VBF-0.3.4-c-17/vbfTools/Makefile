	$(AM_V_at)$(am__mv) $(DEPDIR)/vbfConfig-vbfConfig.Tpo $(DEPDIR)/vbfConfig-vbfConfig.Po
#	$(AM_V_CC)source='vbfConfig.c' object='vbfConfig-vbfConfig.obj' libtool=no \
