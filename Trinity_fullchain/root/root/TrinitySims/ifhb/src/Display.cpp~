void Display::TelescopeGeometry(TEveArrow *tLoc, TEveArrow *tPt){
	TEveManager::Create();
	tLoc->SetMainColor(kBlue);
	tPt->SetMainColor(kRed);

	TEveGeoShape *earth = new TEveGeoShape("Sphere");
	earth->SetShape(new TGeoSphere(6370,6371,38,46,-10,10));
	earth->SetMainColor(kGreen);
	gEve->AddElement(earth);
	gEve->AddElement(tLoc);
	gEve->AddElement(tPt);
	gEve->Redraw3D(kTRUE);

	TTimer timer("gSystem->ProcessEvents();", 50, kFALSE);
	timer.TurnOn();
	TString input = Getline("Type <return> to go on: ");
	timer.TurnOff();
	TEveManager::Terminate();
}
