void Display::ShowHistogram(TH1 *h){
	TCanvas *c = new TCanvas("c", "Canvas",800,500);
	c->cd(1);

	h->Draw("");

	TTimer timer("gSystem->ProcessEvents();", 50, kFALSE);
	timer.TurnOn();
	TString input = Getline("Type <return> to go on: ");
	timer.TurnOff();
}

