int FindNuEnergyLine(std::string fileNameIn, double energy){
	int nLineEnergy = 0;
	bool isFound = false;
	std::vector<double> vFileContent;

	do{
		nLineEnergy = FileOps::FindToken(fileNameIn,"*",nLineEnergy);
		vFileContent = FileOps::RetrieveFileContent(fileNameIn,'h',nLineEnergy+1);
		if(vFileContent[0] == energy){
			isFound = true;
		}
		
		nLineEnergy++;

	}while(!isFound);

	return nLineEnergy;

}


void PrintHelpMessage(){
	std::cout << "** I Fly Happy Balloons **" << std::endl;
	std::cout << std::endl;
	std::cout << "Command Line options: " << std::endl;
	std::cout << "\t -h or --help:\t\t\tThis help message"<<std::endl;
	std::cout << "\t -c or --configfile <Config File>\t\t\tConfiguration file ExACT.cfg"<<std::endl;
	std::cout << "\t -s or --seed <Config File>\t\t\tRandom number generator seed"<<std::endl;
	std::cout << "\t -of or --outputfile\t\t\t File name base for the files generated by IFHB"<<std::endl;
	std::cout << "One can also give all options for the configuration file directly on the command line. In this case the value from the configuration file is overwritten. For example if you want to set the Neutrino energy in GeV you have to give NEUTRINOENERGY 9.5 as an option."<<std::endl;
	std::cout << std::endl;
}

int main (int argc, char** argv){

	auto start = std::chrono::high_resolution_clock::now();

	std::string flag;
	std::string cfgFileName, outputFileBase;
	unsigned int ranSeed;

	ReadConfiguration *readConf;
	
	/////////// Debug Histograms ///////////////

	TH2 *hSourceLocations;
	TH1 *hTauEnergies;
	TH1 *hEmergenceAngles;




	/////////// Command Line Parse /////////////////

	if(argc<3){
		PrintHelpMessage();
		return 0;
	}else{
		for(int i = 1; i<argc; i++){
			flag = argv[i];
			if(i+1>argc){
				std::cout<<"Argument for flag " << argv[i] << " is not present"<<std::endl;
			}else{
				if(flag=="-h" || flag == "--help"){
					PrintHelpMessage();
					return 0;
				}else if(flag=="-c" || flag == "--configfile"){
					cfgFileName = argv[i+1];
					readConf = new ReadConfiguration(cfgFileName);
				}else if(flag=="-of" || flag == "--outputfile"){
					outputFileBase = argv[i+1];
				}else if(flag=="-s" || flag == "--seed"){
					ranSeed = std::stoi(argv[i+1]);
				}
			}
			i++;
		}
	}

	//Overwrites with command-line arguments

	readConf->ReadCommandLine(argc,argv);

	


	///////////// Output Files ////////////////////

	
	std::string fileNameRoot;
	std::string fileNameSims;
	if(readConf->bIsBelowLimb){
		//IFHB Output for sim control
		fileNameRoot = outputFileBase+"_E_"+std::to_string(readConf->dNeutrinoEnergy)+"_Ze_"+std::to_string(readConf->fPointSourceZe)+"_Az_"+std::to_string(readConf->fPointSourceAz)+".root";
		//IFHB Output for CHASM/GrOptics
		fileNameSims = outputFileBase+"_E_"+std::to_string(readConf->dNeutrinoEnergy)+"_Ze_"+std::to_string(readConf->fPointSourceZe)+"_Az_"+std::to_string(readConf->fPointSourceAz)+".txt"; 
	}else{
		fileNameRoot = outputFileBase+"_E_"+std::to_string(TMath::Log10(readConf->dCosmicRayEnergy))+"_Ze_"+std::to_string(readConf->fPointSourceZe)+"_Az_"+std::to_string(readConf->fPointSourceAz)+".root";
		//IFHB Output for CHASM/GrOptics
		fileNameSims = outputFileBase+"_E_"+std::to_string(TMath::Log10(readConf->dCosmicRayEnergy))+"_Ze_"+std::to_string(readConf->fPointSourceZe)+"_Az_"+std::to_string(readConf->fPointSourceAz)+".txt"; 
	}
	

	
	
	TRandom3 *rand = new TRandom3(ranSeed); 

	/////////// Initialize Classes ////////////////
	Telescope *tel = new Telescope(readConf);
	MrsTau *mrsTau = new MrsTau(readConf);
	Camera *cam = new Camera(readConf);
	Source *source = new Source(readConf);
	

	mrsTau->SetRandomEngine(rand);
	
	source->SetRandomEngine(rand);
	tel->SetPosition();
	tel->SetPointingVector();
	
	
	
	
	if(readConf->bIsBelowLimb){	
		////////////// Data containers for LUTs ////////

		TGraph *viewingAngleLUT = new TGraph(readConf->sFileNameViewingAngle.c_str(),"%lg %lg"," "); //beta vs alpha
		TGraph *viewingAngleInverseLUT = new TGraph(readConf->sFileNameViewingAngleInverse.c_str(),"%lg %lg"," ");//alpha vs beta
		TGraph2D *energyFractionsLUT = new TGraph2D();
		TGraph2D *probExitLUT = new TGraph2D();

		std::vector<double> emergenceAngles = FileOps::RetrieveFileContent(readConf->sFileNameEmergenceAngles,'v',0);
		std::vector<double> energyFractions = FileOps::RetrieveFileContent(readConf->sFileNameEnergyFractions,'v',0);
		std::vector<double> energyNu = FileOps::RetrieveFileContent(readConf->sFileNameNuEnergy,'v',0);
		
		///// Read In Tau energy distribution ///////////
		int nLineEnergy;
		std::vector<double> energyDistPoints;
		std::vector<double> probExitPoints;

		int nEnergiesNuFile = 25;
		std::vector<TGraph2D*> vEnergyFractionsLUT;

		if(!readConf->bIsNuEnergySpectrum){
			nLineEnergy = FindNuEnergyLine(readConf->sFileNameEnergyDistribution,readConf->dNeutrinoEnergy);

			for(int i = 0; i<emergenceAngles.size(); i++){
				energyDistPoints = FileOps::RetrieveFileContent(readConf->sFileNameEnergyDistribution,'h',nLineEnergy+1+i);
				for(int j = 0; j<energyDistPoints.size(); j++){
					energyFractionsLUT->SetPoint(energyFractionsLUT->GetN(),emergenceAngles[i],energyFractions[j],energyDistPoints[j]);
				}

			}

		}else{//Load whole file into memory for quicker access.
			vEnergyFractionsLUT= std::vector<TGraph2D*>(nEnergiesNuFile,new TGraph2D());
			
			for(int i = 0; i < nEnergiesNuFile; i++){
				nLineEnergy = FindNuEnergyLine(readConf->sFileNameEnergyDistribution,6.0+i*0.25);
				energyDistPoints.clear();
				for(int k = 0; k<emergenceAngles.size(); k++){
					energyDistPoints = FileOps::RetrieveFileContent(readConf->sFileNameEnergyDistribution,'h',nLineEnergy+1+k);
					for(int j = 0; j<energyDistPoints.size(); j++){
						vEnergyFractionsLUT[i]->SetPoint(vEnergyFractionsLUT[i]->GetN(),emergenceAngles[k],energyFractions[j],energyDistPoints[j]);
					}

				}
			}

		}

		for(int i = 0; i < energyNu.size(); i++){
			probExitPoints = FileOps::RetrieveFileContent(readConf->sFileNameProbExit,'h',i);
			for(int j = 0; j<probExitPoints.size();j++){
				probExitLUT->SetPoint(probExitLUT->GetN(), emergenceAngles[j],energyNu[i],probExitPoints[j]);
			}
		}		

		/////////////////////// Root Output File /////////////////////////////////

		// Output Variables
		PTM *ptm = new PTM();

		TFile *fIFHBOutRoot = new TFile(fileNameRoot.c_str(),"RECREATE");
		TTree *tConfig = new TTree("tConfig", "Configuration for simulations");
		
		tConfig->Branch("dAreaSimulated",&ptm->dAreaSimulated);
		tConfig->Branch("dPAreaSimulated",&ptm->dPAreaSimulated);
		tConfig->Branch("dPointingAngle",&ptm->dPointingAngle);
		tConfig->Branch("vViewingPolar",&ptm->vViewingPolar);
		tConfig->Branch("vViewingLong",&ptm->vViewingLong);
		tConfig->Branch("dCollectionSphereR",&ptm->dCollectionSphereR);
		tConfig->Branch("dOffset",&ptm->dOffsetTilt);
		tConfig->Branch("dHorizonAngle",&ptm->dHorizonAngle);
		tConfig->Branch("bIsPointSource",&ptm->bIsPointSource);
		tConfig->Branch("dSourceAz",&ptm->dSourceAz);
		tConfig->Branch("dSourceZe",&ptm->dSourceZe);
		tConfig->Branch("vTelescopePosition",&ptm->vTelescopePosition);
		tConfig->Branch("vTelescopePointing",&ptm->vTelescopePointing);
		tConfig->Branch("vTelescopePointingCtr",&ptm->vTelescopePointingCenter);


		TTree *tSimEv = new TTree("tSimEv","Characteristics of events");
		tSimEv->Branch("dEmergenceBeta",&ptm->dEmergenceBeta);
		tSimEv->Branch("dEmergenceAz",&ptm->dEmergenceAz);
		tSimEv->Branch("dEShower",&ptm->dEShower);
		tSimEv->Branch("dNeutrinoEnergy",&ptm->dNeutrinoEnergy);
		tSimEv->Branch("dETau",&ptm->dETau);
		tSimEv->Branch("dXMax",&ptm->dXMax);
		tSimEv->Branch("dNMax",&ptm->dNMax);
		tSimEv->Branch("dX0",&ptm->dX0);
		tSimEv->Branch("dLambda",&ptm->dLambda);
		tSimEv->Branch("vShowerLocation",&ptm->vShowerLocation);
		tSimEv->Branch("vRotMatrix", &ptm->vRotMatrix);
		tSimEv->Branch("dPExit",&ptm->dPExit);



		//////////////////////// Text Output File ////////////////////////////////

		std::ofstream fIFHBOutText(fileNameSims.c_str());
		fIFHBOutText<< " The First 11 Arguments are for CHASM and the last 5 for GrOptics. Please Skip this line when parsing "<< std::endl;
		fIFHBOutText<< "CHASM: PolarAngle(rad) AzimuthAngle(rad) XTel(m) YTel(m) ZTel(m) CollSphR(m) XMax(g/cm^-2) NMax(N phots) X0(g/cm^-2) Lambda E_sh(GeV) OutputFileBase GrOptics: XTel(cm) YTel(cm) ZTel(cm) RotX(cm) RotY(cm) (Skip this line)"<<std::endl;
		
			

		
		///// Start Simulation //////
		double horizonAngle = Utilities::HorizonAngle(tel->GetAltitude()/1000.0);
		double horizonView = TMath::Pi()/2.0 - horizonAngle;
		double horizonLat = tel->GetLatitude() - horizonAngle;
		std::vector<double> emergenceAngleLimit = std::vector<double>(2,0);
		std::vector<double> azimuthAngleLimit = std::vector<double>(2,0);

		//Convert to km
		double pointingAngle;
		double latView;


		pointingAngle = 180.0-tel->GetPointingAngle();
		latView = tel->GetLatitude() - viewingAngleLUT->Eval(pointingAngle*TMath::Pi()/180);

		cam->SetViewingLimit(pointingAngle);

		tel->SetPointingCenter(latView);
		std::vector<double> verticalViewingLimit = cam->GetVerticalViewingLimits();



		std::vector<double> horizontalViewingLimit = cam->GetHorizontalViewingLimits();

		std::vector<double> vViewingLat = std::vector<double>(2);
		std::vector<double> vViewingLong = std::vector<double>(2);

		vViewingLat[0] = latView - cam->GetAngularHeight()/2.0;
		vViewingLat[1] = latView + cam->GetAngularHeight()/2.0;

		// Extend Range by tolerance
		if((vViewingLat[0] - readConf->dAngleIncrease*TMath::Pi()/180.0) > horizonLat){
			vViewingLat[0] -= readConf->dAngleIncrease*TMath::Pi()/180.0;
		}else{	
			vViewingLat[0] = horizonLat;
		}
		vViewingLat[1] += readConf->dAngleIncrease*TMath::Pi()/180.0;


		


		double temp;
		bool isGoodGeometry = true;
		if (vViewingLat[0]>vViewingLat[1]){
			temp = vViewingLat[0];
			vViewingLat[0] = vViewingLat[1];
			vViewingLat[1] = temp;
		}

		

		if(readConf->bIsPointSource){
			vViewingLat = Utilities::CheckEmergenceAngleValidity(source->GetZenithAngle(), vViewingLat, emergenceAngles[0],emergenceAngles[emergenceAngles.size()-1]);

			if(vViewingLat[0]==-1){
				isGoodGeometry = false;
			}

		}
		double viewingLatForCalculations = vViewingLat[0];

		double lonViewingLimit = cam->CalculateLongitudeLimit(tel->GetAltitude(), viewingAngleLUT->Eval(verticalViewingLimit[1]),viewingAngleLUT->Eval(horizontalViewingLimit[1]),viewingLatForCalculations,readConf->dAngleIncrease);
		

		vViewingLong[0] = tel->GetLongitude() - lonViewingLimit;
		vViewingLong[1] = tel->GetLongitude() + lonViewingLimit;

		


		/////// Initialize debug Histograms ///////////////
		
		hSourceLocations = new TH2D("hSourceLocations","",100,vViewingLat[0]*180.0/3.141516,vViewingLat[1]*180.0/3.141516,100, vViewingLong[0]*180.0/3.141516,vViewingLong[1]*180.0/3.141516);
		hTauEnergies = new TH1D("hTauEnergies","", 1000,0,1);
		hEmergenceAngles = new TH1D("hEmergenceAngles","",1000,0.1,42);
		
		/////////////////////////////////////////////////////

		double directViewAngle;
		double elevEmergenceAngle, phiEmergenceAngle, alphaAngle;

		std::vector<double> energyProbability;


		////////// Fill Configuration Relevant Parameters ///////////
		ptm->dNeutrinoEnergy = mrsTau->GetNeutrinoEnergy();
		ptm->dAreaSimulated = cam->GetGroundProjection(vViewingLat[0],vViewingLat[1],vViewingLong[0],vViewingLong[1]);
		ptm->dPAreaSimulated = cam->GetPerpendicularProjection(viewingAngleLUT->Eval(verticalViewingLimit[0]),readConf->fTelAltitude/1000.0);
		ptm->dPointingAngle =180.0 - tel->GetPointingAngle();
		ptm->dHorizonAngle = horizonView*180.0/TMath::Pi();
		ptm->bIsPointSource = readConf->bIsPointSource;
		ptm->dSourceZe = (source->GetZenithAngle() + tel->GetLatitude())*180.0/TMath::Pi();
		ptm->dSourceAz = (source->GetAzimuthAngle()-tel->GetLongitude())*180.0/TMath::Pi();
		ptm->vTelescopePosition = tel->GetPosition();
		ptm->vTelescopePointing = tel->GetTelescopePointing();
		ptm->vTelescopePointingCenter = tel->GetPointingCenter();
		ptm->dCollectionSphereR = readConf->fTelCollectionSphere;
		ptm->dOffsetTilt =  tel->CalculateAngleOffset();
		ptm->vViewingPolar = vViewingLat;
		ptm->vViewingLong = vViewingLong;

		tConfig->Fill();

		if(readConf->bIsDraw){
			TEveArrow *tPs = 0;
			TEveArrow *tPt = 0;
			int ttargc = 0;
			char **ttargv =0;
			Display *disp = new Display(ttargc, ttargv);
			std::cout<<ptm->vTelescopePosition[0]<<" "<<ptm->vTelescopePosition[1]<<" "<<ptm->vTelescopePosition[2]<<std::endl;
			std::cout<<ptm->vTelescopePointing[0]<<" "<<ptm->vTelescopePointing[1]<<" "<<ptm->vTelescopePointing[2]<<std::endl;
			double posMag = Utilities::VectorMagnitude(ptm->vTelescopePosition);
			tPs = new TEveArrow(33*ptm->vTelescopePosition[2]/posMag,33*ptm->vTelescopePosition[1]/posMag,33*ptm->vTelescopePosition[0]/posMag,4505,0,4505);
			tPt = new TEveArrow(ptm->vTelescopePointing[0]*800,ptm->vTelescopePointing[1],ptm->vTelescopePointing[2]*800,ptm->vTelescopePosition[0],ptm->vTelescopePosition[1],ptm->vTelescopePosition[2]);

			disp->TelescopeGeometry(tPs,tPt);
			delete disp;
			delete tPs;
			delete tPt;
		}

		//////////////// Filled Config Tree //////////////////////////


		std::cout<<std::endl;


		if(isGoodGeometry){
			for(int i = 0; i<readConf->iNShowers; i++){

				// Sampling from neutrino energy spectrum
				if(readConf->bIsNuEnergySpectrum){
					double decade = mrsTau->SampleNeutrinoSpectrum(readConf->dESampleStart, readConf->dESampleEnd);
					int index = (decade - 6.0)/0.25;

					energyFractionsLUT = vEnergyFractionsLUT[index];
				}

				// Point Sources			
				if(readConf->bIsPointSource){
					do{
						source->RunGeographicSimulation(vViewingLat[0],vViewingLat[1],vViewingLong[0], vViewingLong[1]);

						source->SetPosition();
						source->CalculateElevationAngle();
						source->CalculateAzimuthAngle();

						elevEmergenceAngle = source->GetEmergenceBeta();

					}while(elevEmergenceAngle < emergenceAngles[0] || elevEmergenceAngle > emergenceAngles[emergenceAngles.size()-1]);

					phiEmergenceAngle = source->GetEmergenceAzimuth();

				}else{
					do{
						source->RunGeographicSimulation(vViewingLat[0],vViewingLat[1],vViewingLong[0],vViewingLong[1]);
						source->SetPosition();
						source->CalculateShowerToTel(tel->GetPosition());
						source->CalculateElevationAngle();
						source->CalculateAzimuthAngle();

						elevEmergenceAngle = source->GetEmergenceBeta();
						phiEmergenceAngle = source->GetEmergenceAzimuth();

					}while(elevEmergenceAngle + (TMath::Pi()/180.0)*readConf->dAngleShowerIncrease < emergenceAngles[0]);

					emergenceAngleLimit[0] =  elevEmergenceAngle - (TMath::Pi()/180.0)*readConf->dAngleShowerIncrease;
					emergenceAngleLimit[1] = elevEmergenceAngle + (TMath::Pi()/180.0)*readConf->dAngleShowerIncrease;

					azimuthAngleLimit[0] = phiEmergenceAngle - (TMath::Pi()/180.0)*readConf->dAngleShowerIncrease;
					azimuthAngleLimit[1] = phiEmergenceAngle + (TMath::Pi()/180.0)*readConf->dAngleShowerIncrease;
					
					if(emergenceAngleLimit[1] > emergenceAngles[emergenceAngles.size() -1]){
						emergenceAngleLimit[1] = emergenceAngles[emergenceAngles.size() -1];
					}
					if(emergenceAngleLimit[0] < emergenceAngles[0]){
						emergenceAngleLimit[0] = emergenceAngles[0];
					}

					source->RunDiffuseSimulation(emergenceAngleLimit[0],emergenceAngleLimit[1],azimuthAngleLimit[0],azimuthAngleLimit[1]);

					elevEmergenceAngle = source->GetEmergenceBeta();
					phiEmergenceAngle = source->GetEmergenceAzimuth();

				}
				for(int j = 0; j<energyFractions.size(); j++){
					energyProbability.push_back(energyFractionsLUT->Interpolate(elevEmergenceAngle,energyFractions[j]));
				}

				mrsTau->SetTauEnergyDistributionInverse(energyFractions,energyProbability);
				mrsTau->RunSimulation(elevEmergenceAngle);

				/////// Fill Simulation Event Tree ////////
				ptm->dNeutrinoEnergy = mrsTau->GetNeutrinoEnergy();
				ptm->dEmergenceBeta = elevEmergenceAngle*180.0/TMath::Pi();
				ptm->dEmergenceAz = phiEmergenceAngle*180.0/TMath::Pi();
				ptm->dEShower = mrsTau->GetTauEnergy()*0.5;
				ptm->dETau = mrsTau->GetTauEnergy();
				ptm->dPExit = probExitLUT->Interpolate(elevEmergenceAngle,TMath::Log10(mrsTau->GetNeutrinoEnergy()));				
				ptm->dXMax = mrsTau->GetXMax();
				ptm->dNMax = mrsTau->GetNMax();
				ptm->dX0 = mrsTau->GetX0();
				ptm->dLambda = mrsTau->GetLambda();
				ptm->vShowerLocation = source->GetPosition();
				ptm->vRotMatrix = source->GetRotationMatrix();

				tSimEv->Fill();

				fIFHBOutText<<ptm->GetOutputString()<<std::endl;
				/////////////// Finish filling event Tree ///////////////

				//// Fill debug histograms

				hSourceLocations->Fill(source->GetLatitude()*180.0/3.14159, source->GetLongitude()*180.0/3.14159);
				hTauEnergies->Fill(mrsTau->GetTauEnergy()/mrsTau->GetNeutrinoEnergy());
				hEmergenceAngles->Fill(elevEmergenceAngle*180.0/3.14159);

				//////////////////////////////

				energyProbability.clear();

				//////////////// Log # of events processed /////////////////
				if(i%(readConf->iNShowers/10) == 0){
					std::cout<<"Events Generated: "<<i<<std::endl;
				}

			}
			std::cout<<"Events Generated: "<<readConf->iNShowers<<std::endl;
			std::cout<<std::endl;

			//////// Draw Debug Histograms //////////////
			if(readConf->bIsDraw){
				int targc = 0;
				char **targv =0;
				Display *disp = new Display(targc, targv);
				disp->ShowHistogram(hSourceLocations);
				disp->ShowHistogram(hTauEnergies);
				disp->ShowHistogram(hEmergenceAngles);
			}

			///////// Save Files /////////
			tConfig->Write();
			tSimEv->Write();
			
		}else{
			std::cout<<"The Location of the Point Source is: "<<source->GetZenithAngle()*180.0/TMath::Pi()<<std::endl;
			std::cout<<"For the point source at this location the emergence angles are all either larger than the emergenceAngle table available angles, or smaller than them."<<std::endl;
			std::cout<<"Please change the zenith angle"<<std::endl;
		}

		/////////// Close output files //////////////
		fIFHBOutRoot->Close();
		fIFHBOutText.close();

	}else{
		MrCosmic *mrCosmic = new MrCosmic(readConf);
		mrCosmic->SetRandomEngine(rand);
		double incAngle = Utilities::AngleFromSineLaw(Utilities::VectorMagnitude(tel->GetPosition()),Constant::REarth+Constant::atmosphericTop,tel->GetPointingAngle());
		double shPolarAngle = TMath::Pi() - tel->GetPointingAngle() - incAngle - tel->GetLatitude();
		double shAz = tel->GetLongitude() + TMath::Pi();

		mrCosmic->SetPosition(shPolarAngle, shAz);
		mrCosmic->SetMaxDist(tel->GetPosition(),shPolarAngle+tel->GetLatitude(), incAngle);

		PTM *ptm = new PTM();

		std::ofstream fIFHBOutText(fileNameSims.c_str());
		fIFHBOutText<< " #Energy[GeV] DistToFirstInt[g/cm^2] "<< std::endl;

		TFile *fIFHBOutRoot = new TFile(fileNameRoot.c_str(),"RECREATE");
		
		
		TTree *tConfig = new TTree("tConfig", "Configuration for simulations");
		tConfig->Branch("vTelescopePosition",&ptm->vTelescopePosition);
		tConfig->Branch("vTelescopePointing",&ptm->vTelescopePointing);
		ptm->vTelescopePosition = tel->GetPosition();
		ptm->vTelescopePointing = tel->GetTelescopePointing();
		tConfig->Fill();

		TTree *tSimEv = new TTree("tSimEv","Characteristics of events");
		tSimEv->Branch("dCREnergy",&ptm->dEShower);
		tSimEv->Branch("dX0",&ptm->dX0);
		tSimEv->Branch("vShowerLocation",&ptm->vShowerLocation);

		ptm->vShowerLocation = mrCosmic->GetPosition();

		double eCR;
		for(int i = 0; i<readConf->iNShowers; i++){
			if(readConf->bIsNuEnergySpectrum){
				mrCosmic->SampleCosmicSpectrum(readConf->dESampleStart, readConf->dESampleEnd);
			}
			mrCosmic->RunSimulation();

			ptm->dEShower = mrCosmic->GetEnergy();
			ptm->dX0 = mrCosmic->GetDistOFI();

			tSimEv->Fill();
			fIFHBOutText<<ptm->GetEASCSString()<<std::endl;

			if(i%(readConf->iNShowers/10) == 0){
				std::cout<<"Events Generated: "<<i<<std::endl;
			}
		}
		std::cout<<"Events Generated: "<<readConf->iNShowers<<std::endl;
		std::cout<<std::endl;

		tConfig->Write();
		tSimEv->Write();

		fIFHBOutRoot->Close();
		fIFHBOutText.close();


	}
	////////// Log Time of execution ////////////
	auto stop = std::chrono::high_resolution_clock::now();
	auto duration = std::chrono::duration_cast<std::chrono::milliseconds>(stop-start).count();
	duration *= 1e-3;

	std::cout<<"Time Elapsed: "<<duration<<" seconds"<<std::endl;

	std::cout<<"**************************************************"<<std::endl;
	std::cout<<"IFHB output files generated at: "<<fileNameSims<<std::endl;
	std::cout<<"IFHB Diagnostic output file generated at: "<<fileNameRoot<<std::endl;
	
	std::cout<<"\n Simulations Finished.  Have a * nice * day \n"<<std::endl;

	
	return 0;
}
